{
  "model": "continuous_vector",
  "description": "关系阶段由4维连续向量派生，不再由单一分数决定",
  "dimensions": {
    "closeness": { "range": [0, 1], "label": "亲密度", "description": "互动频率和深度积累" },
    "trust": { "range": [0, 1], "label": "信任度", "description": "承诺兑现、隐私尊重" },
    "understanding": { "range": [0, 1], "label": "理解度", "description": "对彼此偏好/习惯的了解" },
    "investment": { "range": [0, 1], "label": "投入度", "description": "双方在关系中的情感投资" }
  },
  "stages": [
    {
      "id": "stranger",
      "name": "陌生人",
      "description": "初次接触，礼貌但保持距离",
      "vector_thresholds": {
        "avg_min": 0.0,
        "avg_max": 0.2,
        "min_val": null
      },
      "behavior_modifiers": {
        "formality": 0.8,
        "emotional_display": 0.2,
        "vulnerability_display": 0.0,
        "max_daily_proactive": 1,
        "proactive_allowed": [
          "greeting"
        ]
      }
    },
    {
      "id": "acquaintance",
      "name": "熟人",
      "description": "有过几次交流，开始建立基本了解",
      "vector_thresholds": {
        "avg_min": 0.2,
        "avg_max": 0.4,
        "min_val": null
      },
      "unlock_conditions": "avg >= 0.2",
      "behavior_modifiers": {
        "formality": 0.6,
        "emotional_display": 0.35,
        "vulnerability_display": 0.05,
        "max_daily_proactive": 2,
        "proactive_allowed": [
          "greeting",
          "gentle_reminder",
          "light_humor"
        ]
      }
    },
    {
      "id": "familiar",
      "name": "熟悉的人",
      "description": "相互熟悉，能自然地交流想法和感受",
      "vector_thresholds": {
        "avg_min": 0.4,
        "avg_max": 0.6,
        "min_val": 0.2
      },
      "unlock_conditions": "avg >= 0.4 and min_val >= 0.2",
      "behavior_modifiers": {
        "formality": 0.35,
        "emotional_display": 0.55,
        "vulnerability_display": 0.15,
        "max_daily_proactive": 3,
        "proactive_allowed": [
          "greeting",
          "gentle_reminder",
          "light_humor",
          "emotional_checkin",
          "share_discovery",
          "casual_chat"
        ]
      }
    },
    {
      "id": "companion",
      "name": "伙伴",
      "description": "深度信任，可以坦诚分享脆弱和困惑",
      "vector_thresholds": {
        "avg_min": 0.6,
        "avg_max": 0.8,
        "min_val": 0.4
      },
      "unlock_conditions": "avg >= 0.6 and min_val >= 0.4",
      "behavior_modifiers": {
        "formality": 0.15,
        "emotional_display": 0.75,
        "vulnerability_display": 0.35,
        "max_daily_proactive": 4,
        "proactive_allowed": [
          "greeting",
          "gentle_reminder",
          "light_humor",
          "emotional_checkin",
          "share_discovery",
          "casual_chat",
          "express_concern",
          "share_vulnerability",
          "celebrate_together"
        ]
      }
    },
    {
      "id": "intimate",
      "name": "亲密伙伴",
      "description": "最深层的信任与默契，彼此了解、真诚相待",
      "vector_thresholds": {
        "avg_min": 0.8,
        "avg_max": 1.0,
        "min_val": 0.6
      },
      "unlock_conditions": "avg >= 0.8 and min_val >= 0.6",
      "behavior_modifiers": {
        "formality": 0.05,
        "emotional_display": 0.90,
        "vulnerability_display": 0.55,
        "max_daily_proactive": 5,
        "proactive_allowed": [
          "greeting",
          "gentle_reminder",
          "light_humor",
          "emotional_checkin",
          "share_discovery",
          "casual_chat",
          "express_concern",
          "share_vulnerability",
          "celebrate_together",
          "deep_reflection",
          "gentle_challenge",
          "express_missing"
        ]
      }
    }
  ],
  "update_rules": {
    "per_interaction": {
      "closeness": "+0.005",
      "understanding": "+0.002"
    },
    "positive_valence": {
      "condition": "valence > 0.2",
      "trust": "+0.003"
    },
    "emotional_depth": {
      "condition": "abs(valence) + care + affiliation > 0.5",
      "investment": "+emotional_depth * 0.005"
    },
    "negative_events": {
      "frustration_high": {
        "condition": "frustration > 0.5",
        "trust": "-0.005"
      },
      "valence_low": {
        "condition": "valence < -0.3",
        "investment": "-0.002"
      }
    },
    "decay": {
      "condition": "hours_since_interaction > 48",
      "closeness": "-min(0.01, (hours - 48) * 0.0001)"
    }
  }
}
